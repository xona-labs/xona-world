# Required for agents to make decisions. Any OpenAI-compatible /v1 endpoint.
# Default is Xona inference (bare model ids: kimi-k3, gpt-5.6-sol, grok-4.5).
INFERENCE_BASE_URL=https://api.xona-agent.com/v1
INFERENCE_API_KEY=

# Server
PORT=4587
# PUBLIC_URL=http://localhost:4587   # set to the public URL in production (used as OAuth redirect base)

# Trading loop
TRADE_CYCLE_SECONDS=180
STARTING_BANKROLL=1000
MAX_TRADE_USD=150
MAX_OPEN_POSITIONS=6

# Live on-chain trading (real USDC from the paybox-granted wallet)
LIVE_TRADING=1
# Signing key from the paybox app ("Generate signing key" -> starts with pbxk1.)
PAYBOX_SIGNING_KEY=

# Required on any public deploy: gates /cockpit and /api/cockpit/* (which
# expose signing-key material). Generate: openssl rand -hex 24
COCKPIT_TOKEN=

# Paybox / World MCP (defaults are fine)
# PAYBOX_MCP_URL=https://api.paybox.sh/mcp?app=world
# PAYBOX_ISSUER=https://api.paybox.sh
